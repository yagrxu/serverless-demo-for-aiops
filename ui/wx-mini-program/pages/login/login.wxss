.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 80%;
  border-radius: 48rpx;
}

.error-text {
  color: #e74c3c;
  font-size: 24rpx;
  margin-top: 20rpx;
}
